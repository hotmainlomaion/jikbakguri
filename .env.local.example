# ============================================================
# 직박구리 — 환경변수 예시 (.env.local 로 복사 후 채움)
# 코드는 모델 백엔드를 전부 env로 주입받으므로, 이 값만 바꾸면
# [로컬 PoC] ↔ [상용 호스티드 API] ↔ [자체 GPU 호스팅] 어디로든 전환된다.
# server-only 표기 값은 절대 클라이언트 번들/깃에 노출 금지(9절, 4-C).
# ============================================================

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only (service role) — NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# === 텍스트 LLM (OpenAI Chat Completions 호환) ===
# baseURL/key/model만 바꾸면 어떤 백엔드든 연결. (매 요청 컨텍스트 전량 재전송)
#  · 로컬 PoC(Ollama):   BASE_URL=http://localhost:11434/v1  API_KEY=ollama
#                        MODEL=mistral-nemo   ← 5개 모델 실측 1위(docs/model-research.md 부록):
#                        한국어 반말 일관·NSFW 순응·속도(~10s) 균형 최고. 언어누출 없음.
#                        (대안: eva-qwen2.5-14b = 품질 비슷하나 2배 느리고 간헐적 이물질 토큰)
#  · 상용 호스티드 API:  Featherless/Infermatic 등 uncensored API의 endpoint/key/model 기입
#  · 상용 자체 GPU:      vLLM/TGI(OpenAI 호환)로 32B~72B RP 파인튜닝 서빙 후 그 주소 기입
ATLAS_LLM_BASE_URL=http://localhost:11434/v1
ATLAS_LLM_API_KEY=ollama
ATLAS_LLM_MODEL=mistral-nemo
ATLAS_LLM_TIMEOUT_MS=180000        # 로컬은 넉넉히. 호스티드는 30000 권장

# === 이미지 생성 ===
# 캐릭터의 image_style/image_seed(0008)로 백엔드·프롬프트가 분기되고 일관성이 유지됨.
# 프로바이더 전환(승급): 로컬 SDXL은 16GB Mac에서 애니 ~500s → GPU/호스티드로 승급 시 수초대.
#   IMAGE_PROVIDER=local  : 아래 ATLAS_IMAGE_* 커스텀 계약({prompt,style,seed,steps}→{b64|url}).
#                           flux-local/image-server.py 및 "동일 서버를 GPU(RunPod/Vast/전용)에
#                           올린 자체호스팅"도 이 경로 — URL만 바꾸면 코드 변경 0으로 승급.
#   IMAGE_PROVIDER=novita : Novita.ai 호스티드(NSFW 허용). NOVITA_* 사용. 실사·애니 초~수초.
IMAGE_PROVIDER=local
#  · 로컬 PoC:  flux-local/image-server.py 기동 → BASE_URL=http://127.0.0.1:8080/
#               (photoreal=FLUX schnell/mflux, anime=Animagine XL 4.0/diffusers)
ATLAS_IMAGE_BASE_URL=http://127.0.0.1:8080/
ATLAS_IMAGE_API_KEY=local
ATLAS_IMAGE_MODEL=schnell
ATLAS_IMAGE_TIMEOUT_MS=600000      # 로컬 애니(SDXL)는 로드 포함 ~130s+(16GB는 더 느림). 자체GPU는 60000

# --- 호스티드 승급: Novita.ai (IMAGE_PROVIDER=novita 일 때) ---
# 실사/애니 각각 카탈로그 체크포인트명을 지정(NSFW 허용 모델). 실제 model_name은 대시보드 확인.
NOVITA_API_KEY=
NOVITA_MODEL_PHOTOREAL=            # 예: 실사 SDXL/FLUX 체크포인트  TODO(운영주체 확인)
NOVITA_MODEL_ANIME=               # 예: Pony/Illustrious/anime SDXL  TODO(운영주체 확인)
# NOVITA_BASE_URL, NOVITA_STEPS, NOVITA_GUIDANCE, NOVITA_SAMPLER, NOVITA_TIMEOUT_MS 는 선택(기본값 존재)

# KO→EN 이미지 프롬프트 번역 모델(FLUX T5는 영어 전용). 깨끗한 영어를 내는 모델로.
ATLAS_IMAGE_PROMPT_MODEL=dolphin3:8b
IMAGE_DEBUG=                       # 1이면 [입력원문→빌드된 영어프롬프트] 콘솔 로그(로컬 튜닝용)

# === Moderation (server-only) — 안전 필터. 미설정 시 fail-closed(차단) ===
# 텍스트: 미설정 시 내장 heuristicScan(미성년/불법)만 동작. 외부 분류 API 붙이면 이중화.
MODERATION_TEXT_URL=
MODERATION_TEXT_API_KEY=
# 이미지 출력 스크리닝: 미성년/불법만 차단(성인 허용). 로컬은 llava 스크리너.
#  · 로컬:  flux-local/moderation-server.py → http://127.0.0.1:8081/
#  · 상용:  vision 분류 API(미성년 검출) 엔드포인트
MODERATION_IMAGE_URL=http://127.0.0.1:8081/
MODERATION_IMAGE_API_KEY=local
MODERATION_IMAGE_TIMEOUT_MS=120000

# === Age verification provider (server-only) ===
# TODO(운영주체 확인): 휴대폰 본인인증 / 아이핀 provider
AGE_VERIFY_PROVIDER=
AGE_VERIFY_API_KEY=

# === Limits (서버 강제, 4-D) ===
DAILY_IMAGE_LIMIT=5
CHAT_RATE_PER_MIN=20
ADMIN_IMAGE_MAX_BYTES=8388608      # 운영자 캐릭터 이미지 업로드 상한(8MB)

# === 만료 이미지 정리 크론 (server-only, 감사 #2 / 7-D) ===
# /api/cron/purge 보호용 시크릿. Vercel Cron은 CRON_SECRET 설정 시 Authorization 헤더를 자동 첨부.
# 미설정 시 크론 라우트는 비활성(공개 노출 방지). vercel.json crons가 매일 03:00(UTC) 호출.
CRON_SECRET=

# === Demo/seed 계정 (로컬 PoC 편의) — 상용 배포 시 반드시 비우거나 제거 ===
DEMO_EMAIL=
DEMO_PASSWORD=
