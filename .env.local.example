# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-only (service role) — NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# === 텍스트 LLM (OpenAI 호환) ===
# 코드는 OpenAI Chat Completions 호환 — baseURL/key/model만 채우면 어떤 백엔드든 연결.
#  · 로컬 Ollama(테스트):  ATLAS_LLM_BASE_URL=http://localhost:11434/v1
#                          ATLAS_LLM_API_KEY=ollama   ATLAS_LLM_MODEL=dolphin-llama3:8b
#    (성인향이면 uncensored 계열. `ollama pull <name>` 후 MODEL만 변경)
#  · Atlas Cloud(실서비스): 대시보드에서 endpoint/key/model_name 확인 후 기입. TODO(운영주체 확인)
ATLAS_LLM_BASE_URL=
ATLAS_LLM_API_KEY=
ATLAS_LLM_MODEL=
# 이미지 생성. 로컬 FLUX(mflux) 테스트: image-server.py 를 띄우고 BASE_URL을 그 주소로.
#  ⚠️ FLUX.1-schnell/dev 모두 HF 게이트 모델 — `hf auth login`(라이선스 동의+토큰) 선행 필요.
#  · 로컬:      ATLAS_IMAGE_BASE_URL=http://127.0.0.1:8080/   (image-server.py, model=schnell)
#  · Atlas:     대시보드 endpoint/key 기입. TODO(운영주체 확인)
#  주의: 출력 이미지 스크리닝(MODERATION_IMAGE_URL) 미설정 시 생성 이미지는 fail-closed로 차단됨.
ATLAS_IMAGE_BASE_URL=
ATLAS_IMAGE_API_KEY=
ATLAS_IMAGE_MODEL=flux-schnell

# === Moderation (server-only) ===
# TODO(운영주체 확인): 텍스트/이미지 분류 API 채택 후 채움
MODERATION_TEXT_URL=
MODERATION_TEXT_API_KEY=
MODERATION_IMAGE_URL=
MODERATION_IMAGE_API_KEY=

# === Age verification provider (server-only) ===
# TODO(운영주체 확인): 휴대폰 본인인증 / 아이핀 provider
AGE_VERIFY_PROVIDER=
AGE_VERIFY_API_KEY=

# === Limits ===
DAILY_IMAGE_LIMIT=5
CHAT_RATE_PER_MIN=20
ADMIN_IMAGE_MAX_BYTES=8388608   # 운영자 캐릭터 이미지 업로드 상한(8MB)
