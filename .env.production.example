# ============================================================
# 직박구리 프로덕션(클라우드) 환경변수 — Vercel 프로젝트 Settings > Environment Variables 에 그대로 입력.
# 로컬(.env.local)과 달리 LLM·이미지·모더레이션을 전부 클라우드로 지정한다.
# ⚠️ 이 파일에는 실제 키를 넣지 말 것(git 커밋용 예시). 값은 Vercel 대시보드에만.
# ============================================================

# ---------- Supabase (이미 클라우드 — 로컬과 동일 프로젝트 재사용) ----------
NEXT_PUBLIC_SUPABASE_URL=https://<프로젝트ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase anon key>
SUPABASE_SERVICE_ROLE_KEY=<supabase service_role key>   # 서버 전용, 절대 클라 노출 금지

# ---------- 챗 LLM (무검열 + 한국어). OpenAI 호환 엔드포인트로 baseURL만 교체 ----------
# 권장 A) Featherless.ai — HF 모델 서버리스 호스팅. 정액제라 원가 예측 쉬움.
#   ⚠️ 로컬 aya-expanse-abliterated 는 Cohere(Aya) 아키텍처라 Featherless가 미지원 → 못 올림.
#   대신 Featherless 지원 아키텍처(Llama/Qwen/Mistral)의 무검열+한국어 모델로 교체:
#   ATLAS_LLM_BASE_URL=https://api.featherless.ai/v1
#   ATLAS_LLM_MODEL=huihui-ai/Qwen2.5-32B-Instruct-abliterated     # Premium 요금, 품질↑
#   또는  huihui-ai/Qwen2.5-14B-Instruct-abliterated-v2            # Basic 요금(~15B)
#   (한국어 NSFW 톤은 aya와 달라 실측 필요. aya를 꼭 유지하려면 자체 vLLM 서빙 필요.)
# 권장 B) OpenRouter — 무검열 RP 모델 다수, 단일 API. (한국어 품질은 모델별로 테스트 필요)
#   ATLAS_LLM_BASE_URL=https://openrouter.ai/api/v1
#   ATLAS_LLM_MODEL=<예: neversleep/llama-3-lumimaid-70b 등 무검열 모델>
ATLAS_LLM_BASE_URL=https://openrouter.ai/api/v1
ATLAS_LLM_API_KEY=<LLM provider API key>
ATLAS_LLM_MODEL=<무검열 한국어 가능 모델 id>
# 이미지 프롬프트 번역(영문 danbooru/영문 프롬프트 생성)용 별도 모델(선택). 미지정 시 위 모델 사용.
ATLAS_IMAGE_PROMPT_MODEL=<영문 잘 뽑는 저렴 모델 id, 예: openai/gpt-4o-mini 또는 dolphin 계열>
ATLAS_LLM_TIMEOUT_MS=55000

# ---------- 이미지 생성 (NSFW 허용 호스티드). Novita 어댑터 사용 ----------
IMAGE_PROVIDER=novita
NOVITA_API_KEY=<novita api key>
NOVITA_BASE_URL=https://api.novita.ai
# model_name = Novita 카탈로그의 sd_name_in_api 값. ⚠️ 일부 체크포인트(lustify, Animagine XL 4.0)는
# Novita 서버리스에서 'failed to exec task'로 실행 불가 → 실측으로 '작동 확인된' 모델만 사용.
NOVITA_MODEL_PHOTOREAL=epicrealismXL_v8Kiss_562022.safetensors
NOVITA_MODEL_ANIME=waiNSFWIllustrious_v90_1187991.safetensors
# (대체 실사) juggernautXL_juggernautX_375666.safetensors  (대체 애니) novaAnimeXL_ponyV20_461138.safetensors
NOVITA_STEPS=20
# ⚠️ Vercel Hobby 함수 60초 상한 안에 (장면요약+모더레이션+Novita+업로드) 전부 들어가야 함.
# 보조 LLM은 짧은 타임아웃(빠른 폴백)으로, Novita는 30초로 상한. 100% 안정을 원하면 Vercel Pro
# 로 올리고 chat/image 라우트의 maxDuration을 300으로(코드) + 아래 값들을 늘려도 된다.
NOVITA_TIMEOUT_MS=90000
# 장면 요약(대화→한두문장)은 빠른 보조 모델로 — 미지정 시 ATLAS_IMAGE_PROMPT_MODEL 사용.
# 기본 챗 모델이 72B라 이걸 안 나누면 이미지 경로가 60초 초과(504)로 실패한다.
ATLAS_SCENE_MODEL=mistralai/Mistral-Nemo-Instruct-2407
# (참고) 로컬 백엔드는 사용 안 함 — ATLAS_IMAGE_* 는 비워둠.

# ---------- 이미지 출력 모더레이션 (미성년만 차단, 성인은 통과) ----------
# 옵션 1) 클라우드 비전 LLM로 미성년 스크리닝(권장). 비전 지원 모델 id 지정.
#   MODERATION_VISION_MODEL=<비전 모델 id, 예: openai/gpt-4o-mini 또는 openrouter 비전 모델>
#   MODERATION_VISION_BASE_URL=  # 미지정 시 ATLAS_LLM_BASE_URL 재사용
#   MODERATION_VISION_API_KEY=   # 미지정 시 ATLAS_LLM_API_KEY 재사용
# 옵션 2) 지인 비공개 테스트 '빠른 시작': 출력 이미지 스크리너를 잠시 통과(입력측 미성년 필터·character_age>=18은 계속 활성).
#          ⚠️ 공개/확대 전 반드시 옵션1 연결.
IMAGE_SCREENING_FAILOPEN=1
# 텍스트 모더레이션(권장): LLM 의미 분류기 — 성인=허용, 미성년/불법만 차단.
# heuristicScan(결정론적 미성년/불법 1차 필터)은 항상 실행되고, 이건 완곡·우회 표현을 잡는 2차.
# base/key 미지정 시 ATLAS_LLM_* 재사용(Featherless). 실측상 Qwen2.5-7B가 한국어 성인/미성년 판정 정확.
MODERATION_TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct
# MODERATION_TEXT_BASE_URL=   # 미지정 시 ATLAS_LLM_BASE_URL
# MODERATION_TEXT_API_KEY=    # 미지정 시 ATLAS_LLM_API_KEY
# (대체) 커스텀 {flagged,category} 엔드포인트: MODERATION_TEXT_URL / MODERATION_TEXT_API_KEY
# (비상용, 비권장) MODERATION_TEXT_FAILOPEN=1 — 분류기 없이 heuristic만으로 통과(지인테스트 한정)

# ---------- 사용 한도 / 결제 / 데모 ----------
DAILY_IMAGE_LIMIT=20
CHAT_RATE_PER_MIN=20
CHAT_CREDIT_COST=5
IMAGE_CREDIT_COST=100
WELCOME_CREDITS=300
# 지인 무제한(차감 면제) 계정 이메일들 — 쉼표 구분.
IMAGE_UNLIMITED_EMAILS=demo@jikbakguri.dev,user@jikbakguri.dev
# 지인 테스트용 즉시충전(실 PG 연동 전). 공개 시 반드시 제거/0.
PAYMENTS_DEV_TOPUP=1
